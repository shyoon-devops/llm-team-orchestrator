# Agent Team Orchestrator — Environment Variables
# Copy this file to .env and fill in your values.

# === CLI Authentication ===
# Claude Code uses firstParty auth by default (no key needed for most setups).
# Set this only if using a proxy or custom endpoint.
# ANTHROPIC_API_KEY=sk-ant-...

# Codex CLI (OpenAI)
# OPENAI_API_KEY=sk-...

# Gemini CLI (Google)
# GOOGLE_API_KEY=AIza...

# === Server ===
ORCH_HOST=0.0.0.0
ORCH_PORT=8000
ORCH_LOG_LEVEL=info

# === Orchestrator ===
# ORCH_PLANNER_MODEL=claude-sonnet-4-20250514
# ORCH_SYNTHESIZER_MODEL=claude-sonnet-4-20250514
# ORCH_WORKTREE_BASE_DIR=/tmp/orchestrator-worktrees
# ORCH_PRESET_DIRS=./presets

# === Checkpointing ===
# ORCH_CHECKPOINT_ENABLED=true
# ORCH_CHECKPOINT_DB_PATH=./data/checkpoints.sqlite
